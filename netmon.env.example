# Copy to netmon.env (which is gitignored) and fill in.
#   cp netmon.env.example netmon.env && chmod 600 netmon.env
# Then: docker-compose up -d --build netmon

# --- SMTP (Resend) ---
# API key from https://resend.com/api-keys — required to send alert emails.
# Without it, alerts are written to the SQLite alerts table but no email is sent.
NETMON_SMTP_PASSWORD=re_xxxxxxxxxxxxxxxx
# Defaults shown; override only if needed:
#NETMON_SMTP_HOST=smtp.resend.com
#NETMON_SMTP_PORT=587
#NETMON_SMTP_USER=resend
#NETMON_SMTP_FROM=from@your_address
#NETMON_RECIPIENT=to@your_address
#NETMON_SUBJECT_PREFIX=[netmon]

# --- MaxMind GeoLite2 (optional but recommended) ---
# Free signup: https://www.maxmind.com/en/geolite2/signup
# Without these, threat-intel matching still works; ASN/country baseline does not.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# --- Tunables (optional, defaults shown) ---
# UTC hour (0-23) at which the daily new-ASN/new-country digest email fires.
# Empty days are skipped (no email sent).
#NETMON_DAILY_SUMMARY_HOUR_UTC=6
#NETMON_LOOP_INTERVAL_SEC=120
#NETMON_TI_LOOP_INTERVAL_SEC=86400
#NETMON_DEDUPE_HOURS=6
#NETMON_DEDUPE_LOW_HOURS=24
#NETMON_MIN_BYTES=2048
#NETMON_MIN_PACKETS=2
#NETMON_EMAIL_MIN_SEVERITY=low
#NETMON_ERROR_EMAIL_INTERVAL_SEC=3600
#NETMON_FLOWS_ROTATE_SEC=3600
#NETMON_FLOWS_RETAIN=4

# --- Web dashboard ---
# host:port the dashboard binds to (network_mode: host, so this is the
# host-visible address). Default is the LAN-reachable port; set to
# 127.0.0.1:49210 to restrict to the host or front it with a reverse proxy.
#NETMON_WEB_LISTEN=0.0.0.0:49210
